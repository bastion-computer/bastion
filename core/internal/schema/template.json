{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bastion.computer/schemas/template.json",
  "$defs": {
    "runAction": {
      "type": "object",
      "properties": {
        "run": {
          "type": "string"
        }
      },
      "required": ["run"],
      "additionalProperties": false
    },
    "actionList": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/runAction"
      }
    }
  },
  "type": "object",
  "properties": {
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "vcpu": {
          "type": "number",
          "minimum": 1
        },
        "memory": {
          "type": "integer",
          "minimum": 1
        },
        "volume": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "env": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "actions": {
      "type": "object",
      "properties": {
        "init": {
          "$ref": "#/$defs/actionList"
        }
      },
      "required": ["init"],
      "additionalProperties": false
    }
  },
  "required": ["actions"],
  "additionalProperties": false
}
