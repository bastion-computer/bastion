{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bastion.computer/schemas/template.json",
  "$defs": {
    "presetAction": {
      "type": "object",
      "properties": {
        "use": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9_-]*$"
        },
        "with": {
          "type": "object",
          "propertyNames": {
            "pattern": "^[A-Za-z][A-Za-z0-9_]*$"
          },
          "additionalProperties": {
            "type": ["string", "number", "boolean"]
          }
        },
        "context": {
          "description": "Arbitrary JSON context exposed to the action package."
        }
      },
      "required": ["use"],
      "additionalProperties": false
    },
    "runAction": {
      "type": "object",
      "properties": {
        "run": {
          "type": "string"
        },
        "working_directory": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": ["run"],
      "additionalProperties": false
    },
    "action": {
      "oneOf": [
        {
          "$ref": "#/$defs/presetAction"
        },
        {
          "$ref": "#/$defs/runAction"
        }
      ]
    },
    "actionList": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/action"
      }
    },
    "opencodeAuthInfo": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "oauth"
            },
            "refresh": {
              "type": "string"
            },
            "access": {
              "type": "string"
            },
            "expires": {
              "type": "integer",
              "minimum": 0
            },
            "accountId": {
              "type": "string"
            },
            "enterpriseUrl": {
              "type": "string"
            }
          },
          "required": ["type", "refresh", "access", "expires"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "api"
            },
            "key": {
              "type": "string"
            },
            "metadata": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          },
          "required": ["type", "key"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "wellknown"
            },
            "key": {
              "type": "string"
            },
            "token": {
              "type": "string"
            }
          },
          "required": ["type", "key", "token"],
          "additionalProperties": false
        }
      ]
    },
    "opencodeAuth": {
      "type": "object",
      "propertyNames": {
        "minLength": 1
      },
      "additionalProperties": {
        "$ref": "#/$defs/opencodeAuthInfo"
      }
    },
    "opencodeAgent": {
      "type": "object",
      "properties": {
        "working_directory": {
          "type": "string",
          "minLength": 1
        },
        "auth": {
          "$ref": "#/$defs/opencodeAuth"
        },
        "config": {
          "type": "object"
        }
      },
      "additionalProperties": false
    },
    "agents": {
      "type": "object",
      "properties": {
        "opencode": {
          "$ref": "#/$defs/opencodeAgent"
        }
      },
      "required": ["opencode"],
      "additionalProperties": false
    }
  },
  "type": "object",
  "properties": {
    "agents": {
      "$ref": "#/$defs/agents"
    },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "vcpu": {
          "type": "integer",
          "minimum": 1
        },
        "memory": {
          "type": "integer",
          "minimum": 1
        },
        "volume": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "actions": {
      "type": "object",
      "properties": {
        "init": {
          "$ref": "#/$defs/actionList"
        },
        "start": {
          "$ref": "#/$defs/actionList"
        }
      },
      "required": ["init"],
      "additionalProperties": false
    }
  },
  "required": ["agents", "actions"],
  "additionalProperties": false
}
