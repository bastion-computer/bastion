---
import config from "virtual:starlight/user-config";

import LanguageSelect from "@astrojs/starlight/components/LanguageSelect.astro";
import Search from "starlight-theme-black/overrides/Search.astro";
import SiteTitle from "starlight-theme-black/overrides/SiteTitle.astro";
import SocialIcons from "starlight-theme-black/overrides/SocialIcons.astro";
import ThemeSelect from "starlight-theme-black/overrides/ThemeSelect.astro";

const headerLinks = [
  {
    label: "Blog",
    href: "https://blog.bastion.computer/",
  },
];

/**
 * Render the `Search` component if Pagefind is enabled or the default search component has been overridden.
 */
const shouldRenderSearch =
  config.pagefind ||
  config.components.Search !== "@astrojs/starlight/components/Search.astro";
---

<div class="site-title-wrapper">
  <SiteTitle />
  {
    headerLinks.length > 0 && (
      <nav class="header-links" aria-label="Site links">
        {headerLinks.map(({ label, href }) => (
          <a class="header-link" {href}>
            {label}
          </a>
        ))}
      </nav>
    )
  }
</div>

<button class="show-modal" popovertargetaction="toggle" popovertarget="drawer">
  <svg
    xmlns="http://www.w3.org/2000/svg"
    fill="none"
    viewBox="0 0 24 24"
    stroke-width="1.5"
    stroke="currentColor"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      d="M3.75 9h16.5m-16.5 6.75h16.5"></path>
  </svg>
  <span class="sr-only">Toggle Menu</span>
</button>

<div class="header-right">
  {shouldRenderSearch && <Search />}

  <nav class="header-nav">
    <div>
      <SocialIcons />
    </div>
    <div>
      <ThemeSelect />
    </div>
    <div>
      <LanguageSelect />
    </div>
  </nav>
</div>

<style>
  .site-title-wrapper {
    display: flex;
    align-items: center;
    min-width: 0;
    margin-right: 0.75rem;
  }

  @media (min-width: 1024px) {
    .site-title-wrapper {
      margin-right: 1rem;
    }
  }

  .header-links {
    display: flex;
    flex: none;
    gap: 0.75rem;
    align-items: center;
    font-size: 0.875rem;
    line-height: 1.25rem;
  }

  .header-link {
    color: color-mix(in oklab, var(--foreground) 80%, transparent);
    text-decoration: none;
    transition-property:
      color, background-color, border-color, text-decoration-color, fill, stroke;
    transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
    transition-duration: 0.15s;
    white-space: nowrap;
  }

  .header-link:hover,
  .header-link:focus-visible {
    color: var(--foreground);
  }

  .show-modal {
    all: unset;
    display: inline-flex;
    margin-right: 0.5rem;
    margin-left: -0.5rem;
    height: 2rem;
    width: 2rem;
    align-items: center;
    justify-content: center;
    padding-bottom: 0.5rem;
    padding-top: 0.5rem;
    font-size: 1rem;
    line-height: 1.5rem;
  }

  @media (min-width: 768px) {
    .show-modal {
      display: none;
    }
  }

  .show-modal > svg {
    width: 1.5rem;
    height: 1.5rem;
  }

  .header-right {
    gap: 0.5rem;
    justify-content: space-between;
    align-items: center;
    flex: 1 1 0%;
    display: flex;
    min-width: 0;
  }

  @media (min-width: 768px) {
    .header-right {
      justify-content: flex-end;
    }
  }

  .header-nav {
    gap: 0.125rem;
    align-items: center;
    display: flex;
  }
</style>
